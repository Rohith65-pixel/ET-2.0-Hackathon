            159,
            471,
            174
        ],
        "page_idx": 4
    },
    {
        "type": "text",
        "text": "2. If this is not possible, contact the nearest Grund fos company or service workshop.",
        "bbox": [
            61,
            176,
            469,
            205
        ],
        "page_idx": 4
    },
    {
        "type": "header",
        "text": "5. Maintenance",
        "bbox": [
